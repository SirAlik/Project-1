# ------------------------------------------------
# Package manager lock files
# ------------------------------------------------
# This project uses npm, so package-lock.json MUST stay committed.
# Do not ignore package-lock.json.
yarn.lock
pnpm-lock.yaml
bun.lockb

# ------------------------------------------------
# Static assets
# ------------------------------------------------
# Do NOT ignore /public because it may contain required app assets.
# Ignore only temporary/generated assets outside public if needed.
*.tmp.png
*.tmp.jpg
*.tmp.jpeg
*.tmp.webp
*.tmp.svg

# ------------------------------------------------
# Source maps
# ------------------------------------------------
*.map