# ================================================================
# School OS / Sidra OS — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env.local وأضف القيم الحقيقية
# ================================================================

# Supabase — مطلوب
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT — مطلوب لتشفير active_persona cookie
JWT_SECRET=

# App URL — مطلوب لروابط الدعوة
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (Anthropic) — مطلوب لطبقة ai_insights
ANTHROPIC_API_KEY=

# Webhooks / Cron
# BIOMETRIC_WEBHOOK_SECRET: مطلوب لـ webhook البصمة (fail-closed بدونه).
BIOMETRIC_WEBHOOK_SECRET=
# CRON_SECRET: **مطلوب في الإنتاج** — وظائف cron وEdge `generate-qms-pdf` تفشل-مغلقة بدونه.
# يجب أن يطابق قيمته في DB: app_private.secrets (name='cron_secret'). ولّد سرّاً قوياً واحداً
# واضبطه في كلٍّ من: (1) متغيّر بيئة Vercel CRON_SECRET، و(2) app_private.secrets.cron_secret.
CRON_SECRET=

# ================================================================
# أسرار قاعدة البيانات (app_private.secrets) — تُضبط server-side فقط، لا في هذا الملف:
#   - ledger_secret_salt : مُدوّر عشوائياً في DB (M82/الإطلاق) — لا يُكشف ولا يُلتزَم.
#   - cron_secret        : = CRON_SECRET أعلاه (نفس القيمة).
#   - cron_site_url       : رابط النشر الفعلي (https://<app>.vercel.app) — يضبطه المالك قبل الإطلاق.
# ================================================================

# سكريبت إنشاء system_owner (scripts/init-system-owner.mjs فقط)
SYSTEM_OWNER_PASSWORD=
