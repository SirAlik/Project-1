# ================================================================
# School OS / Sidra OS — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env.local وأضف القيم الحقيقية
# ================================================================

# وضع العرض التجريبي — اضبطه على true لتشغيل التطبيق بدون Supabase حقيقي
# عند التفعيل: auth مُتجاوَز + بيانات تجريبية ثابتة (لا قراءة/كتابة حقيقية)
NEXT_PUBLIC_DEMO_MODE=false

# Supabase — مطلوب عند NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT — مطلوب لتشفير active_persona cookie
JWT_SECRET=

# App URL — مطلوب لروابط الدعوة
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (Anthropic) — مطلوب لطبقة ai_insights
ANTHROPIC_API_KEY=

# Webhooks / Cron — اختياري في بيئة التطوير
BIOMETRIC_WEBHOOK_SECRET=
CRON_SECRET=

# سكريبت إنشاء system_owner (scripts/init-system-owner.mjs فقط)
SYSTEM_OWNER_PASSWORD=
